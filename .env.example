# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.
#
# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.
#
# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# =============================================================================
# Database — Railway managed PostgreSQL connection string
# Railway: copy from your PostgreSQL service → Variables tab
# Local: postgresql://postgres:password@localhost:5432/fantasy-finals
# =============================================================================
DATABASE_URL="postgresql://username:password@host:5432/fantasy-finals"

# =============================================================================
# NextAuth.js (next-auth v5) — Authentication
# Generate AUTH_SECRET with: npx auth secret  OR  openssl rand -base64 32
# AUTH_URL: set to your Railway app URL in production; omit for local dev
# =============================================================================
AUTH_SECRET=""
# AUTH_URL="https://your-app.railway.app"  # Required in production only

# =============================================================================
# Google OAuth Provider (Story 1.2)
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
# =============================================================================
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# =============================================================================
# Email / Magic Link Provider (Story 1.2)
# SMTP server credentials for sending magic-link sign-in emails
# =============================================================================
AUTH_EMAIL_SERVER_HOST="smtp.example.com"
AUTH_EMAIL_SERVER_PORT="587"
AUTH_EMAIL_SERVER_USER="user@example.com"
AUTH_EMAIL_SERVER_PASSWORD=""
AUTH_EMAIL_FROM="noreply@fantasy-finals.app"

# =============================================================================
# Firebase / FCM — Web Push Notifications (Story 1.5)
# Create a Firebase project at: https://console.firebase.google.com
# NEXT_PUBLIC_* vars are safe to expose to the browser
# =============================================================================
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
FIREBASE_ADMIN_PROJECT_ID=""
FIREBASE_ADMIN_CLIENT_EMAIL=""
FIREBASE_ADMIN_PRIVATE_KEY=""
