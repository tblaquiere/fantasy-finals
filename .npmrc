public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*

# Include optional native binaries for both macOS (dev) and Linux x64 (Railway)
# so the frozen lockfile works on both platforms.
supportedArchitectures.os[]=current
supportedArchitectures.os[]=linux
supportedArchitectures.cpu[]=current
supportedArchitectures.cpu[]=x64