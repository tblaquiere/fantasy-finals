generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id          Int      @id @default(autoincrement())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([name])
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserRole {
  participant
  commissioner
  admin
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(participant)
  accounts          Account[]
  posts             Post[]
  sessions          Session[]
  pushSubscriptions PushSubscription[]
  createdLeagues    League[]      @relation("LeagueCreator")
  participations    Participant[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model League {
  id                   String        @id @default(cuid())
  name                 String
  seriesId             String        @map("series_id")
  clockDurationMinutes Int           @map("clock_duration_minutes")
  inviteToken          String?       @unique @map("invite_token")
  createdById          String        @map("created_by_id")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")
  deletedAt            DateTime?     @map("deleted_at")

  createdBy       User                @relation("LeagueCreator", fields: [createdById], references: [id])
  participants    Participant[]
  games           Game[]
  picks           Pick[]
  preferenceItems PreferenceListItem[]
  mozgovWindows   MozgovWindow[]

  @@map("leagues")
}

model Participant {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  leagueId       String   @map("league_id")
  isCommissioner Boolean  @default(false) @map("is_commissioner")
  joinedAt       DateTime @default(now()) @map("joined_at")

  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  league          League              @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  draftSlots      DraftSlot[]
  picks           Pick[]
  preferenceItems PreferenceListItem[]
  mozgovWindows   MozgovWindow[]

  @@unique([userId, leagueId])
  @@map("participants")
}

// ── Story 3.3: Draft Order Generation ────────────────────────────

model Game {
  id           String   @id @default(cuid())
  leagueId     String   @map("league_id")
  nbaGameId    String   @map("nba_game_id") // loose reference — NbaGame may not exist yet
  gameNumber   Int      @map("game_number") // 1-based within series for this league
  status       String   @default("pending") // pending | draft-open | active | final
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  draftOpensAt  DateTime? @map("draft_opens_at")
  draftClosesAt DateTime? @map("draft_closes_at")

  league        League         @relation(fields: [leagueId], references: [id])
  draftSlots    DraftSlot[]
  picks         Pick[]
  mozgovWindows MozgovWindow[]

  @@unique([leagueId, nbaGameId])
  @@map("games")
}

model DraftSlot {
  id            String   @id @default(cuid())
  gameId        String   @map("game_id")
  participantId String   @map("participant_id")
  pickPosition  Int      @map("pick_position") // 1 = picks first
  clockStartsAt  DateTime? @map("clock_starts_at")
  clockExpiresAt DateTime? @map("clock_expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  game        Game        @relation(fields: [gameId], references: [id])
  participant Participant @relation(fields: [participantId], references: [id])

  pick Pick?

  @@unique([gameId, participantId])
  @@unique([gameId, pickPosition])
  @@map("draft_slots")
}

// ── Story 3.5: Pick (eligible player list needs this for eligibility queries) ─

model Pick {
  id            String   @id @default(cuid())
  draftSlotId   String?  @unique @map("draft_slot_id") // null for Mozgov replacement picks
  nbaPlayerId   Int      @map("nba_player_id")
  participantId String   @map("participant_id")
  gameId        String   @map("game_id")
  leagueId      String   @map("league_id")
  method         String   @default("manual") // manual | auto-preference | auto-system | mozgov-manual | mozgov-auto-preference | mozgov-auto-system
  confirmed      Boolean  @default(false)
  overridden     Boolean  @default(false) // true if commissioner overrode the pick
  voidedByMozgov Boolean  @default(false) @map("voided_by_mozgov") // true if original pick replaced via Mozgov
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  draftSlot   DraftSlot?  @relation(fields: [draftSlotId], references: [id])
  nbaPlayer   NbaPlayer   @relation(fields: [nbaPlayerId], references: [nbaPlayerId])
  participant Participant @relation(fields: [participantId], references: [id])
  game        Game        @relation(fields: [gameId], references: [id])
  league      League      @relation(fields: [leagueId], references: [id])

  @@unique([leagueId, gameId, nbaPlayerId]) // FR8(c): no double-draft in same game
  @@map("picks")
}

// ── Story 3.8: Preference List ───────────────────────────────────

model PreferenceListItem {
  id            String   @id @default(cuid())
  participantId String   @map("participant_id")
  leagueId      String   @map("league_id")
  nbaPlayerId   Int      @map("nba_player_id")
  rank          Int      // 1 = most preferred
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  league      League      @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  nbaPlayer   NbaPlayer   @relation(fields: [nbaPlayerId], references: [nbaPlayerId])

  @@unique([participantId, leagueId, nbaPlayerId])
  @@map("preference_list_items")
}

// ── Story 5.1: Mozgov Replacement Window ─────────────────────────

model MozgovWindow {
  id              String   @id @default(cuid())
  gameId          String   @map("game_id")
  leagueId        String   @map("league_id")
  participantId   String   @map("participant_id")
  originalPickId  String   @map("original_pick_id")
  status          String   @default("pending") // pending | active | completed | expired
  order           Int      // 1 = selects first (inverse draft order)
  clockStartsAt   DateTime? @map("clock_starts_at")
  clockExpiresAt  DateTime? @map("clock_expires_at")
  replacementPickId String? @map("replacement_pick_id")
  triggeredBy     String   @default("auto") // auto | commissioner
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  game        Game        @relation(fields: [gameId], references: [id])
  league      League      @relation(fields: [leagueId], references: [id])
  participant Participant @relation(fields: [participantId], references: [id])

  @@unique([gameId, participantId])
  @@map("mozgov_windows")
}

// ── Story 3.1: NBA Stats API Integration ─────────────────────────

model NbaSeries {
  id            String   @id @default(cuid())
  seriesId      String   @unique @map("series_id")
  homeTeamId    Int      @map("home_team_id")
  awayTeamId    Int      @map("away_team_id")
  homeTeamName  String   @map("home_team_name")
  awayTeamName  String   @map("away_team_name")
  homeTricode   String   @map("home_tricode")
  awayTricode   String   @map("away_tricode")
  seasonYear    String   @map("season_year")
  round         Int
  status        String   @default("upcoming")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  games NbaGame[]

  @@map("nba_series")
}

model NbaGame {
  id             String   @id @default(cuid())
  nbaGameId      String   @unique @map("nba_game_id")
  seriesDbId     String   @map("series_db_id")
  gameDate       DateTime @map("game_date")
  status         String   @default("scheduled")
  period         Int      @default(0)
  gameClock      String?  @map("game_clock")
  homeTeamScore  Int      @default(0) @map("home_team_score")
  awayTeamScore  Int      @default(0) @map("away_team_score")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  series    NbaSeries  @relation(fields: [seriesDbId], references: [id])
  boxScores BoxScore[]

  @@map("nba_games")
}

model NbaPlayer {
  id           String   @id @default(cuid())
  nbaPlayerId  Int      @unique @map("nba_player_id")
  firstName    String   @map("first_name")
  familyName   String   @map("family_name")
  teamId       Int      @map("team_id")
  teamTricode  String   @map("team_tricode")
  position     String   @default("")
  jersey       String   @default("")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  boxScores       BoxScore[]
  picks           Pick[]
  preferenceItems PreferenceListItem[]

  @@map("nba_players")
}

model BoxScore {
  id                    String   @id @default(cuid())
  nbaGameId             String   @map("nba_game_id")
  nbaPlayerId           Int      @map("nba_player_id")
  minutes               Int      @default(0)
  points                Int      @default(0)
  rebounds               Int      @default(0)
  assists               Int      @default(0)
  steals                Int      @default(0)
  blocks                Int      @default(0)
  fantasyPoints         Int      @default(0) @map("fantasy_points")
  period                Int      @default(0)
  isFinal               Boolean  @default(false) @map("is_final")
  correctedPoints       Int?     @map("corrected_points")
  correctedRebounds     Int?     @map("corrected_rebounds")
  correctedAssists      Int?     @map("corrected_assists")
  correctedSteals       Int?     @map("corrected_steals")
  correctedBlocks       Int?     @map("corrected_blocks")
  correctedFantasyPoints Int?    @map("corrected_fantasy_points")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  game   NbaGame   @relation(fields: [nbaGameId], references: [nbaGameId])
  player NbaPlayer @relation(fields: [nbaPlayerId], references: [nbaPlayerId])

  @@unique([nbaGameId, nbaPlayerId])
  @@map("box_scores")
}
